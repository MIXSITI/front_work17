43.\"})]});}","map":{"version":3,"names":["useEffect","useMemo","useState","jsx","_jsx","jsxs","_jsxs","NOTES_STORAGE_KEY","OfflineNotes","notes","setNotes","noteText","setNoteText","saved","localStorage","getItem","JSON","parse","error","setItem","stringify","trimmedText","trim","handleSubmit","event","preventDefault","prev","className","children","onSubmit","type","placeholder","value","onChange","target","required","length","map","note","index","concat"],"sources":["C:/Users/Svetlana/Desktop/mirea/front/work 13/frontend/src/components/OfflineNotes.jsx"],"sourcesContent":["import { useEffect, useMemo, useState } from 'react';\n\nconst NOTES_STORAGE_KEY = 'offlineNotes';\n\nexport default function OfflineNotes() {\n  const [notes, setNotes] = useState([]);\n  const [noteText, setNoteText] = useState('');\n\n  useEffect(() => {\n    try {\n      const saved = localStorage.getItem(NOTES_STORAGE_KEY);\n      setNotes(saved ? JSON.parse(saved) : []);\n    } catch (error) {\n      setNotes([]);\n    }\n  }, []);\n\n  useEffect(() => {\n    localStorage.setItem(NOTES_STORAGE_KEY, JSON.stringify(notes));\n  }, [notes]);\n\n  const trimmedText = useMemo(() => noteText.trim(), [noteText]);\n\n  const handleSubmit = (event) => {\n    event.preventDefault();\n\n    if (!trimmedText) {\n      return;\n    }\n\n    setNotes((prev) => [trimmedText, ...prev]);\n    setNoteText('');\n  };\n\n  return (\n    <section className=\"offline-notes\">\n      <div className=\"section-header\">\n        <h2>Офлайн заметки</h2>\n      </div>\n\n      <form className=\"offline-notes__form\" onSubmit={handleSubmit}>\n        <input\n          type=\"text\"\n          placeholder=\"Введите задачу или заметку\"\n          value={noteText}\n          onChange={(event) => setNoteText(event.target.value)}\n          required\n        />\n        <button type=\"submit\" className=\"btn btn-add\">Добавить</button>\n      </form>\n\n      {notes.length ? (\n        <ul className=\"offline-notes__list\">\n          {notes.map((note, index) => (\n            <li key={`${note}-${index}`}>{note}</li>\n          ))}\n        </ul>\n      ) : (\n        <p className=\"offline-notes__empty\">Список пуст. Добавьте первую заметку.</p>\n      )}\n    </section>\n  );\n}\n"],"mappings":"AAAA,OAASA,SAAS,CAAEC,OAAO,CAAEC,QAAQ,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAErD,KAAM,CAAAC,iBAAiB,CAAG,cAAc,CAExC,cAAe,SAAS,CAAAC,YAAYA,CAAA,CAAG,CACrC,KAAM,CAACC,KAAK,CAAEC,QAAQ,CAAC,CAAGR,QAAQ,CAAC,EAAE,CAAC,CACtC,KAAM,CAACS,QAAQ,CAAEC,WAAW,CAAC,CAAGV,QAAQ,CAAC,EAAE,CAAC,CAE5CF,SAAS,CAAC,IAAM,CACd,GAAI,CACF,KAAM,CAAAa,KAAK,CAAGC,YAAY,CAACC,OAAO,CAACR,iBAAiB,CAAC,CACrDG,QAAQ,CAACG,KAAK,CAAGG,IAAI,CAACC,KAAK,CAACJ,KAAK,CAAC,CAAG,EAAE,CAAC,CAC1C,CAAE,MAAOK,KAAK,CAAE,CACdR,QAAQ,CAAC,EAAE,CAAC,CACd,CACF,CAAC,CAAE,EAAE,CAAC,CAENV,SAAS,CAAC,IAAM,CACdc,YAAY,CAACK,OAAO,CAACZ,iBAAiB,CAAES,IAAI,CAACI,SAAS,CAACX,KAAK,CAAC,CAAC,CAChE,CAAC,CAAE,CAACA,KAAK,CAAC,CAAC,CAEX,KAAM,CAAAY,WAAW,CAAGpB,OAAO,CAAC,IAAMU,QAAQ,CAACW,IAAI,CAAC,CAAC,CAAE,CAACX,QAAQ,CAAC,CAAC,CAE9D,KAAM,CAAAY,YAAY,CAAIC,KAAK,EAAK,CAC9BA,KAAK,CAACC,cAAc,CAAC,CAAC,CAEtB,GAAI,CAACJ,WAAW,CAAE,CAChB,OACF,CAEAX,QAAQ,CAAEgB,IAAI,EAAK,CAACL,WAAW,CAAE,GAAGK,IAAI,CAAC,CAAC,CAC1Cd,WAAW,CAAC,EAAE,CAAC,CACjB,CAAC,CAED,mBACEN,KAAA,YAASqB,SAAS,CAAC,eAAe,CAAAC,QAAA,eAChCxB,IAAA,QAAKuB,SAAS,CAAC,gBAAgB,CAAAC,QAAA,cAC7BxB,IAAA,OAAAwB,QAAA,CAAI,iFAAc,CAAI,CAAC,CACpB,CAAC,cAENtB,KAAA,SAAMqB,SAAS,CAAC,qBAAqB,CAACE,QAAQ,CAAEN,YAAa,CAAAK,QAAA,eAC3DxB,IAAA,UACE0B,IAAI,CAAC,MAAM,CACXC,WAAW,CAAC,+IAA4B,CACxCC,KAAK,CAAErB,QAAS,CAChBsB,QAAQ,CAAGT,KAAK,EAAKZ,WAAW,CAACY,KAAK,CAACU,MAAM,CAACF,KAAK,CAAE,CACrDG,QAAQ,MACT,CAAC,cACF/B,IAAA,WAAQ0B,IAAI,CAAC,QAAQ,CAACH,SAAS,CAAC,aAAa,CAAAC,QAAA,CAAC,kDAAQ,CAAQ,CAAC,EAC3D,CAAC,CAENnB,KAAK,CAAC2B,MAAM,cACXhC,IAAA,OAAIuB,SAAS,CAAC,qBAAqB,CAAAC,QAAA,CAChCnB,KAAK,CAAC4B,GAAG,CAAC,CAACC,IAAI,CAAEC,KAAK,gBACrBnC,IAAA,OAAAwB,QAAA,CAA8BU,IAAI,KAAAE,MAAA,CAAtBF,IAAI,MAAAE,MAAA,CAAID,KAAK,CAAc,CACxC,CAAC,CAC