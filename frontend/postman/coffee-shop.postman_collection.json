  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "adminAccessToken",
      "value": ""
    },
    {
      "key": "adminRefreshToken",
      "value": ""
    },
    {
      "key": "sellerAccessToken",
      "value": ""
    },
    {
      "key": "userAccessToken",
      "value": ""
    },
    {
      "key": "productId",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    }
