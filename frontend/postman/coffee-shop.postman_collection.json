            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Американо",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Напитки",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Классический американо",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "280",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "25",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "GET /api/products/:id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "PUT /api/products/:id",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{sellerAccessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Большой американо",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Напитки",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Увеличенная порция классического кофе",
                  "type": "text"
                },
                {
                  "key": "price",
                  "value": "320",
                  "type": "text"
                },
                {
                  "key": "stock",
                  "value": "20",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "DELETE /api/products/:id",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        }
